# Firebase web app config. Copy to .env.local and fill from the Firebase
# console (Project settings > General > Your apps > SDK setup, "Config").
# These are public client keys; access is controlled by firestore.rules.
# Without them the app runs in pure-localStorage mode (no cross-device sharing).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
