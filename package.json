{
  "name": "promenadquiz",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "firebase emulators:exec --only firestore --project demo-test \"vitest run --config vitest.integration.config.ts\"",
    "test:emulators": "firebase emulators:start --only firestore --project demo-test",
    "verify": "npm run lint && npm run typecheck && npm run test:coverage && npm run test:integration",
    "prepare": "husky"
  },
  "dependencies": {
    "firebase": "^12.15.0",
    "qrcode.react": "^4.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "firebase-tools": "^14.27.0",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.61.1",
    "vite": "^5.4.6",
    "vitest": "^2.1.1"
  }
}
